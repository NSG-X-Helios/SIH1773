{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "fs:default",
    "fs:scope",
    "fs:allow-resource-read-recursive",
    "fs:allow-appdata-write-recursive",
    "dialog:default"
  ]
}
