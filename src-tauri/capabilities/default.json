{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "fs:default",
    "fs:scope",
    "fs:allow-resource-read-recursive",
    "fs:allow-appdata-write-recursive",
    "dialog:default",
    "shell:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "exec-sh",
          "cmd": "sh",
          "args": [
            "-c",
            {
              "validator": ".+"
            }
          ],
          "sidecar": false
        },
        {
          "name": "exec-pwsh",
          "cmd": "powershell.exe",
          "args": [
            "-Command",
            {
              "validator": ".+"
            }
          ],
          "sidecar": false
        }
      ]
    },
    "os:default"
  ]
}
