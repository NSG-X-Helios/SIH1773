{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "xhelios",
  "version": "0.1.0",
  "identifier": "com.xhelios.dev",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "xhelios",
        "maximized": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri://localhost ipc: ipc://localhost asset://localhost http://asset.localhost blob:; img-src 'self' tauri://localhost asset://localhost http://asset.localhost; connect-src 'self' tauri://localhost ipc://localhost asset://localhost http://asset.localhost blob:",
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA", "$APPDATA/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage", "msi", "nsis", "app", "dmg"],
    "resources": ["resources/"],
    "externalBin": ["binaries/convertor"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
